generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model data_schema {
  rootid           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id               Int      @unique @default(autoincrement())
  prev_id          Int?
  name             String   @db.VarChar(255)
  json             Json     @default("{}")
  flag             String?  @default("draft") @db.VarChar(50)
  activate         Boolean  @default(true)
  modify_datetime  String?  @db.VarChar(15)

  previous         data_schema?  @relation("SchemaVersion", fields: [prev_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions         data_schema[] @relation("SchemaVersion")

  views            view[]
  forms            form[]
  records          data[]

  @@index([flag])
  @@index([prev_id])
}

model view {
  rootid            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id                Int      @unique @default(autoincrement())
  prev_id           Int?
  data_schema_id    Int
  view_type         String   @db.VarChar(50)
  name              String?  @db.VarChar(255)
  json_table_config Json     @default("{}")
  flag              String?  @default("draft") @db.VarChar(50)
  activate          Boolean  @default(true)
  modify_datetime   String?  @db.VarChar(15)

  previous          view?         @relation("ViewVersion", fields: [prev_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions          view[]        @relation("ViewVersion")
  schema            data_schema   @relation(fields: [data_schema_id], references: [id])

  @@index([data_schema_id])
  @@index([view_type])
}

model form {
  rootid            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id                Int      @unique @default(autoincrement())
  prev_id           Int?
  data_id           Int
  name              String?  @db.VarChar(255)
  json_form_config  Json     @default("{}")
  flag              String?  @default("draft") @db.VarChar(50)
  activate          Boolean  @default(true)
  modify_datetime   String?  @db.VarChar(15)

  previous          form?         @relation("FormVersion", fields: [prev_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions          form[]        @relation("FormVersion")
  schema            data_schema   @relation(fields: [data_id], references: [id])

  @@index([data_id])
}

model data {
  rootid            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id                Int      @unique @default(autoincrement())
  prev_id           Int?
  data_schema_id    Int
  data              Json     @default("{}")
  flag              String?  @default("active") @db.VarChar(50)
  activate          Boolean  @default(true)
  modify_datetime   String?  @db.VarChar(15)

  previous          data?         @relation("DataVersion", fields: [prev_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions          data[]        @relation("DataVersion")
  schema            data_schema   @relation(fields: [data_schema_id], references: [id])

  @@index([data_schema_id])
  @@index([activate])
}
